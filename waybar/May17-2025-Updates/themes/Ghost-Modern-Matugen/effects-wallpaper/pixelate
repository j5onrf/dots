#!/bin/bash

# Relies on $wallpaper (original wallpaper path) and $used_wallpaper (output path for pixelated version)
# being set as environment variables by the calling script.

# --- ImageMagick Pixelate Settings ---
# Adjust PIXELATE_SCALE_WIDTH to control the "chunkiness".
# Smaller value = larger, chunkier "pixels" = generally faster initial downscale.
# For a 3440px wide screen:
# 120 -> ~28px wide blocks
# 96  -> ~36px wide blocks
# 80  ->  43px wide blocks
# 60  -> ~57px wide blocks (very chunky)
PIXELATE_SCALE_WIDTH=96 # Good starting point for noticeable pixelation on 3440px wide

if [ -z "$wallpaper" ] || [ -z "$used_wallpaper" ]; then
  ml4w_cache_file="$HOME/.config/ml4w/cache/current_wallpaper"
  if [ -f "$ml4w_cache_file" ]; then
    wallpaper=$(cat "$ml4w_cache_file")
  else
    echo "Error: \$wallpaper not set and ML4W cache not found." >&2
    exit 1
  fi
  if [ -z "$used_wallpaper" ]; then
    used_wallpaper="$HOME/.config/ml4w/cache/pixelate_effect_output.png"
  fi
fi

# Get original dimensions to scale back up accurately
original_width=$(identify -format "%w" "$wallpaper")
original_height=$(identify -format "%h" "$wallpaper")

# Step 1: Downscale to create the pixelated effect.
#         Height is calculated automatically to maintain aspect ratio.
# Step 2: Upscale back to original dimensions using nearest-neighbor (Point)
#         to keep the sharp pixel block look.
if magick "$wallpaper" \
           -filter Point \
           -scale "${PIXELATE_SCALE_WIDTH}x" \
           -scale "${original_width}x${original_height}!" \
           "$used_wallpaper"; then
  : # Success
else
  cp "$wallpaper" "$used_wallpaper" # Fallback
fi