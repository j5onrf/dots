<?xml version="1.0" encoding="UTF-8"?>
<language id="notes" name="Personal Notes" version="2.0" _section="Other">
  <metadata>
    <property name="mimetypes">text/plain</property>
    <property name="globs">*.txt;notes.md</property>
  </metadata>
  <definitions>
    <context id="notes">
      <include>
        <!-- This group captures the whole line but colors the dashes blue -->
        <context id="header-dashes" style-ref="def:constant">
          <match>^--+|--+$</match>
        </context>

        <!-- Ollama/System Commands -->
        <context id="commands" style-ref="def:keyword">
          <keyword>ollama</keyword>
          <keyword>sudo</keyword>
          <keyword>rm</keyword>
          <keyword>create</keyword>
        </context>

        <!-- File Paths -->
        <context id="paths" style-ref="def:string">
          <match>/[a-zA-Z0-9._/-]+</match>
        </context>
      </include>
    </context>
  </definitions>
</language>
